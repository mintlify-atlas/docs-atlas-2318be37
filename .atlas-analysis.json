  "keyFeatures": [
    "Technical-economic proposal (PTE) management with workflow tracking",
    "Work order (OTE) creation, scheduling, and reprogramming",
    "Production tracking with daily and monthly reporting",
    "GPU management and photographic evidence tracking",
    "Master catalogs for products, sites, clients, and concepts",
    "Query center with global search and interactive dashboards",
    "Import/export capabilities for Excel annexes and MPP schedules",
    "Activity logging and user permission management",
    "Email notifications and automated report generation",
    "Schedule version control and task dependency tracking"
  ],
